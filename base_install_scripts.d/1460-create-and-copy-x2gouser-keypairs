#/bin/bash -e

# create custom directory and generate keys, if not already present
mkdir -p  ./custom/x2goserver/user{1,2}
[ -s ./custom/x2goserver/user1/id_ed25519 ] || ssh-keygen -N '' -t ed25519 -C "x2goserver demo env user1" -f ./custom/x2goserver/user1/id_ed25519
[ -s ./custom/x2goserver/user2/id_ed25519 ] || ssh-keygen -N '' -t ed25519 -C "x2goserver demo env user2" -f ./custom/x2goserver/user2/id_ed25519
[ -s ./custom/x2goserver/user1/id_ed25519.pub ] || ssh-keygen -f ./custom/x2goserver/user1/id_ed25519 -y > ./custom/x2goserver/user1/id_ed25519.pub
[ -s ./custom/x2goserver/user2/id_ed25519.pub ] || ssh-keygen -f ./custom/x2goserver/user2/id_ed25519 -y > ./custom/x2goserver/user2/id_ed25519.pub

# copy pubkeys to root directory so we can retrieve them later
rsync -aP --include="ed25519.pub" ./custom/x2goserver/user{1,2}/ $MOUNTPOINT/root/pubkeys
